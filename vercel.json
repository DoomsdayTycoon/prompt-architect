{
  "outputDirectory": "static",
  "cleanUrls": true,
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/checkout", "destination": "/api/checkout" },
    { "source": "/api/redeem", "destination": "/api/redeem" },
    { "source": "/api/webhook", "destination": "/api/webhook" },
    { "source": "/api/portal", "destination": "/api/portal" },
    { "source": "/blog/promptperfect-alternatives-2026", "destination": "/blog-promptperfect-alternatives.html" },
    { "source": "/blog/how-to-write-ai-prompts-that-work", "destination": "/blog-how-to-write-ai-prompts.html" },
    { "source": "/((?!api/|promptperfect-alternative|blog-).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://www.proarch.tech" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
